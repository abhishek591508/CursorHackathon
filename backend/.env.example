# Use production on Render/Fly/Docker so logs are JSON and CORS/security match prod.
NODE_ENV=development
# Use 4000 if Next.js runs on 3000 locally
PORT=4000
FRONTEND_URL=http://localhost:3000
# Optional: legacy Vite app on 5173
# CORS_EXTRA=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/civic_platform
LOG_LEVEL=info
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
# Grant admin in MongoDB (Compass or mongosh), then use /admin/leaders in the web app:
# db.users.updateOne({ email: "you@example.com" }, { $set: { role: "super_admin" } })
REDIS_URL=redis://127.0.0.1:6379
# OPENAI_API_KEY=sk-...
# Apify: related Google results on posts (https://console.apify.com/account/integrations)
# APIFY_TOKEN=apify_api_...
# Optional override (default apify/google-search-scraper):
# APIFY_GOOGLE_SEARCH_ACTOR_ID=apify/google-search-scraper
# Exa semantic search (https://dashboard.exa.ai)
# EXA_API_KEY=...
# Vercel v0 Platform (https://v0.dev/chat/settings/keys)
# V0_API_KEY=v1_...
# TRUST_PROXY=1
# COMMUNITY_VERIFY_THRESHOLD=5
